# --- Freshdesk ---
FRESHDESK_DOMAIN=bookleafpublishing
FRESHDESK_API_KEY=

# Comma-separated agent IDs whose replies must NOT count as human.
# Critical: without this every ticket looks human-replied.
# Find via GET /agents, or list the AI agent's email and resolve the id.
AI_AGENT_IDS=

# Optional: Rama (CS manager) id. Tickets still assigned to her are
# escalated-but-not-yet-assigned to an executive and excluded from "assigned".
RAMA_AGENT_ID=

# Optional: comma-separated agent IDs to hide from leaderboards.
# Use for teammates who've left or aren't on the current active CS roster.
EXCLUDED_AGENT_IDS=

# --- Neon Postgres ---
DATABASE_URL=

# --- Email (Resend) ---
RESEND_API_KEY=
SUMMARY_EMAIL_FROM=
# Comma-separated.
SUMMARY_EMAIL_TO=

# --- Slack ---
# Used by the daily/weekly Resend summary jobs (optional).
SLACK_WEBHOOK_URL=

# Bot token for escalation update DMs + channel posts. Required scopes:
#   chat:write   — send messages
#   im:write     — open direct-message conversations to users
# users:read is NOT needed — member IDs come from the manually-curated
# team_members table at /admin/team, not from Slack lookups.
SLACK_BOT_TOKEN=

# Channel ID (Cxxxx...) for the #cs-escalations channel. Same payload
# the credited agent gets via DM is also posted here for manager visibility.
# Leave blank to disable the channel post (DMs still go out).
SLACK_ESCALATION_CHANNEL_ID=

# Public origin of the dashboard — used to build the "Open in dashboard"
# button in Slack messages. Defaults to the Vercel production URL.
DASHBOARD_ORIGIN=https://support-performance-tracker.vercel.app

# --- Cron auth ---
CRON_SECRET=

# Informational; business logic always uses Asia/Kolkata regardless.
TZ=Asia/Kolkata
